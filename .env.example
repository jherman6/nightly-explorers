# ─────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nightlyexplorers.com

# ─────────────────────────────────────────────────────────
# Lead capture (waitlist + contact form)
# Point this at any webhook-based tool: Zapier, Make,
# a Supabase Edge Function, ConvertKit, Mailchimp, etc.
# If left blank, submissions are simply logged on the server
# (visible in Vercel's function logs) so nothing is lost
# while you wire up a real destination.
# ─────────────────────────────────────────────────────────
LEADS_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────
# Supabase (optional — stores waitlist + contact leads in a database)
# Settings > API Keys in your Supabase project dashboard.
# Use the SECRET key here, never the publishable one (this only
# runs server-side, in API routes).
# ─────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ─────────────────────────────────────────────────────────
# Stripe (optional — only needed once you're ready to charge)
# Leave these blank and the waitlist form will just collect
# name + email. Fill them in and it will create a Stripe
# Checkout session (subscription, 7-day free trial) instead.
#
# STRIPE_SECRET_KEY  -> Stripe Dashboard > Developers > API keys
# STRIPE_PRICE_ID    -> Stripe Dashboard > Product catalog >
#                       your subscription product > Price ID
#                       (looks like price_1Q...)
# ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_TRIAL_DAYS=7
